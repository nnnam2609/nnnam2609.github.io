---
import { biography } from '../../data/home';
import { siteProfile } from '../../data/site';

const contactLinks = [
  siteProfile.email && { href: `mailto:${siteProfile.email}`, label: 'Institutional email' },
  siteProfile.github && { href: siteProfile.github, label: 'GitHub' },
  siteProfile.linkedin && { href: siteProfile.linkedin, label: 'LinkedIn' },
].filter(Boolean) as { href: string; label: string }[];
---

<section class="editorial-section bio-section" aria-labelledby="bio-title">
  <div class="container bio-grid">
    <header>
      <p class="section-label">04 / Biography</p>
      <h2 id="bio-title">Research across speech, vision, and anatomy.</h2>
    </header>

    <figure>
      <img
        src="/profile-nhat-nam.webp"
        alt="Portrait of Nhat-Nam Nguyen"
        width="384"
        height="384"
        loading="lazy"
        decoding="async"
      />
      <figcaption>{siteProfile.name} · {siteProfile.location}</figcaption>
    </figure>

    <div class="bio-copy">
      {biography.map((paragraph) => <p>{paragraph}</p>)}
    </div>

    <aside aria-labelledby="correspondence-title">
      <p class="section-label" id="correspondence-title">Correspondence</p>
      <p>For research questions, collaborations, or project discussions.</p>
      <ul role="list">
        {
          contactLinks.map(({ href, label }) => (
            <li>
              <a href={href}>
                {label} <span aria-hidden="true">↗</span>
              </a>
            </li>
          ))
        }
      </ul>
    </aside>
  </div>
</section>

<style>
  .bio-section {
    background: var(--color-surface);
  }

  .bio-grid,
  header,
  .bio-copy,
  aside,
  ul {
    display: grid;
  }

  .bio-grid {
    gap: 2.5rem;
  }

  header {
    gap: 0.9rem;
  }

  .section-label,
  figcaption {
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  h2 {
    max-width: 15ch;
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 5vw, 4.6rem);
    font-weight: 500;
    letter-spacing: -0.045em;
    line-height: 1;
  }

  figure {
    width: min(100%, 15rem);
    margin: 0;
  }

  img {
    width: 100%;
    aspect-ratio: 4 / 5;
    border: 1px solid var(--color-line);
    object-fit: cover;
    object-position: center 32%;
  }

  figcaption {
    padding-top: 0.65rem;
    color: var(--color-muted);
    line-height: 1.45;
  }

  .bio-copy {
    gap: 1rem;
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.5vw, 1.8rem);
    line-height: 1.38;
  }

  .bio-copy p + p {
    color: var(--color-muted);
    font-family: var(--font-sans);
    font-size: 0.92rem;
  }

  aside {
    align-content: start;
    gap: 0.8rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-line-strong);
  }

  aside > p:not(.section-label) {
    color: var(--color-muted);
    font-size: 0.85rem;
  }

  ul {
    gap: 0.15rem;
  }

  a {
    display: inline-flex;
    min-height: 40px;
    gap: 0.4rem;
    align-items: center;
    color: var(--color-text);
    font-size: 0.84rem;
    font-weight: 700;
    text-decoration: none;
  }

  a span {
    color: var(--color-accent);
  }

  @media (min-width: 58rem) {
    .bio-grid {
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: 2rem;
    }

    header {
      grid-column: 1 / 6;
    }

    figure {
      grid-column: 1 / 4;
      grid-row: 2;
    }

    .bio-copy {
      grid-column: 4 / 10;
      grid-row: 2;
    }

    aside {
      grid-column: 10 / 13;
      grid-row: 2;
    }
  }
</style>
