---
import { researchThemes } from '../../data/home';
---

<section class="section themes-section" aria-labelledby="themes-title">
  <div class="container">
    <div class="section-heading-row">
      <div class="section-heading">
        <p class="eyebrow">Research map</p>
        <h2 id="themes-title">Three views of the same question</h2>
        <p class="lede">
          How can sound, visual evidence, and anatomical structure support models that generalize
          beyond one speaker?
        </p>
      </div>
      <a class="text-link" href="/research/">Explore all themes</a>
    </div>

    <div class="theme-grid">
      {
        researchThemes.map((theme, index) => (
          <article class="theme-card">
            <div class="theme-visual" aria-hidden="true">
              {theme.key === 'speech' && (
                <svg viewBox="0 0 320 130" focusable="false">
                  <path
                    class="theme-wave"
                    d="M20 69h18l10-24 13 52 14-86 15 118 15-91 15 61 15-30 15 4 14-18 15 33 15-54 15 76 15-46 15 18h18"
                  />
                </svg>
              )}
              {theme.key === 'aai' && (
                <svg viewBox="0 0 320 130" focusable="false">
                  <path
                    class="theme-contour"
                    d="M93 24c78-19 141 31 137 91-2 4-3 8-4 11M210 126c-39 3-71-14-82-40-9-23 2-49 24-57 19-7 40 3 46 20 4 14-5 28-19 32"
                  />
                  <circle cx="93" cy="24" r="4" />
                  <circle cx="230" cy="115" r="4" />
                  <circle cx="179" cy="81" r="4" />
                </svg>
              )}
              {theme.key === 'mri' && (
                <svg viewBox="0 0 320 130" focusable="false">
                  <rect x="88" y="12" width="144" height="106" rx="12" />
                  <path
                    class="theme-mri"
                    d="M143 30c49-8 82 25 78 63-2 8-5 15-9 21M199 116c-29 2-51-11-58-29-6-17 3-34 19-39 13-4 28 3 31 14"
                  />
                </svg>
              )}
            </div>
            <div class="theme-copy">
              <span>{String(index + 1).padStart(2, '0')}</span>
              <h3>{theme.title}</h3>
              <p>{theme.description}</p>
              <ul role="list">
                {theme.topics.map((topic) => (
                  <li>{topic}</li>
                ))}
              </ul>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .themes-section {
    background: color-mix(in srgb, var(--accent-soft) 22%, var(--paper));
  }

  .theme-grid {
    display: grid;
    gap: 1rem;
  }

  .theme-card {
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--paper-raised);
  }

  .theme-visual {
    min-height: 8rem;
    border-bottom: 1px solid var(--line);
    background:
      linear-gradient(var(--line) 1px, transparent 1px),
      linear-gradient(90deg, var(--line) 1px, transparent 1px);
    background-size: 32px 32px;
  }

  .theme-visual svg {
    width: 100%;
  }

  .theme-wave,
  .theme-contour,
  .theme-mri {
    fill: none;
    stroke: var(--accent-strong);
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2.5;
    vector-effect: non-scaling-stroke;
  }

  .theme-contour + circle,
  .theme-contour ~ circle {
    fill: var(--signal);
  }

  .theme-visual rect {
    fill: var(--ink);
    opacity: 0.92;
  }

  .theme-mri {
    stroke: var(--paper-raised);
  }

  .theme-copy {
    display: grid;
    padding: 1.3rem;
    gap: 0.75rem;
  }

  .theme-copy > span {
    color: var(--signal);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 800;
  }

  .theme-copy p,
  .theme-copy li {
    color: var(--ink-soft);
  }

  .theme-copy ul {
    display: grid;
    gap: 0.45rem;
    padding-top: 0.35rem;
    border-top: 1px solid var(--line);
  }

  .theme-copy li {
    position: relative;
    padding-left: 0.9rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
  }

  .theme-copy li::before {
    position: absolute;
    top: 0.6em;
    left: 0;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--accent);
    content: '';
  }

  @media (min-width: 48rem) {
    .theme-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
