---
import type { CollectionEntry } from 'astro:content';
import ProjectCard from '../cards/ProjectCard.astro';

interface Props {
  projects: CollectionEntry<'projects'>[];
}

const { projects } = Astro.props;
---

<section class="section" aria-labelledby="featured-projects-title">
  <div class="container">
    <div class="section-heading-row">
      <div class="section-heading">
        <p class="eyebrow">Selected work</p>
        <h2 id="featured-projects-title">Research questions made visible</h2>
        <p class="lede">
          Current research directions shown without unverified metrics, publication claims, or
          repository links.
        </p>
      </div>
      <a class="text-link" href="/projects/">View all projects</a>
    </div>
    <div class="card-grid three">
      {projects.map((project) => <ProjectCard {project} />)}
    </div>
  </div>
</section>
