---
import { getCollection } from 'astro:content';
import ResearchCard from '../../components/cards/ResearchCard.astro';
import ContentLayout from '../../layouts/ContentLayout.astro';

const research = (await getCollection('research')).sort((a, b) => a.data.order - b.data.order);
---

<ContentLayout
  title="Research"
  description="A research programme connecting acoustic speech signals, real-time MRI, anatomical representation, and cross-speaker learning."
  eyebrow="Speech · vision · articulation"
>
  <section class="section research-list" aria-label="Research themes">
    <div class="container">
      {research.map((item, index) => <ResearchCard research={item} {index} />)}
    </div>
  </section>
</ContentLayout>

<style>
  .research-list {
    padding-top: clamp(2rem, 5vw, 4rem);
  }
</style>
