---
import { heroContent } from '../../data/home';
import { siteProfile } from '../../data/site';
import { cvPath } from '../../utils/cv';
import ResearchFigure from './ResearchFigure.astro';
---

<section class="editorial-hero" aria-labelledby="home-title">
  <div class="container hero-grid">
    <header class="hero-heading">
      <p class="hero-index">Research portfolio / 2026</p>
      <h1 id="home-title">
        {heroContent.titleLines.map((line) => <span>{line}</span>)}
      </h1>
    </header>

    <div class="researcher-meta" aria-label="Researcher details">
      <p class="researcher-name">{siteProfile.name}</p>
      <dl>
        <div>
          <dt>Role</dt>
          <dd>{siteProfile.position}</dd>
        </div>
        <div>
          <dt>Affiliation</dt>
          <dd>{siteProfile.affiliation}</dd>
        </div>
        <div>
          <dt>Base</dt>
          <dd>{siteProfile.location}</dd>
        </div>
      </dl>
    </div>

    <div class="hero-statement">
      <p class="primary-statement">{heroContent.introduction}</p>
      <p>{heroContent.supporting}</p>
      <div class="hero-links">
        <a class="editorial-link" href="/research/"
          >View research <span aria-hidden="true">→</span></a
        >
        {
          cvPath && (
            <a class="quiet-link" href={cvPath}>
              Download CV
            </a>
          )
        }
      </div>
    </div>

    <div class="hero-figure">
      <ResearchFigure />
    </div>
  </div>
</section>

<style>
  .editorial-hero {
    padding-block: clamp(3.5rem, 8vw, 8rem) clamp(4.5rem, 10vw, 9rem);
  }

  .hero-grid {
    display: grid;
    gap: 2.5rem;
  }

  .hero-heading {
    display: grid;
    gap: 1rem;
  }

  .hero-index,
  dt {
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 650;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h1 {
    display: grid;
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: clamp(4.1rem, 17vw, 10.5rem);
    font-weight: 500;
    letter-spacing: -0.075em;
    line-height: 0.76;
    text-wrap: nowrap;
  }

  h1 span:last-child {
    color: var(--color-accent);
    font-style: italic;
    letter-spacing: -0.085em;
  }

  .researcher-meta {
    display: grid;
    align-content: start;
    gap: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-line-strong);
  }

  .researcher-name {
    font-family: var(--font-display);
    font-size: 1.45rem;
    line-height: 1.1;
  }

  dl,
  dl div {
    display: grid;
    gap: 0.2rem;
  }

  dl {
    gap: 0.9rem;
  }

  dd {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.88rem;
    line-height: 1.45;
  }

  .hero-statement {
    display: grid;
    align-content: start;
    gap: 1.15rem;
    max-width: 37rem;
  }

  .primary-statement {
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3.2vw, 2.35rem);
    line-height: 1.18;
  }

  .hero-statement > p:not(.primary-statement) {
    color: var(--color-muted);
    font-size: 0.98rem;
  }

  .hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.4rem;
    align-items: center;
    padding-top: 0.6rem;
  }

  .editorial-link,
  .quiet-link {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    color: var(--color-text);
    font-weight: 700;
    text-decoration: none;
  }

  .editorial-link {
    gap: 0.55rem;
    border-bottom: 1px solid var(--color-text);
  }

  .editorial-link span {
    color: var(--color-accent);
  }

  .quiet-link {
    color: var(--color-muted);
    font-size: 0.83rem;
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .hero-figure {
    align-self: end;
  }

  @media (min-width: 58rem) {
    .hero-grid {
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: 2rem clamp(1rem, 1.8vw, 2rem);
      align-items: start;
    }

    .hero-heading {
      grid-column: 1 / 9;
      grid-row: 1;
    }

    .researcher-meta {
      grid-column: 10 / 13;
      grid-row: 1;
      margin-top: 1.8rem;
    }

    .hero-statement {
      grid-column: 1 / 7;
      grid-row: 2;
      margin-top: 1.8rem;
    }

    .hero-figure {
      grid-column: 7 / 13;
      grid-row: 2;
      margin-top: -5rem;
    }
  }

  @media (min-width: 80rem) {
    .hero-figure {
      grid-column: 8 / 13;
      margin-top: -8rem;
    }
  }

  @media (max-width: 24rem) {
    h1 {
      font-size: clamp(3.55rem, 19vw, 4.6rem);
    }
  }
</style>
