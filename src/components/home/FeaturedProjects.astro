---
import type { CollectionEntry } from 'astro:content';
import ProjectCard from '../cards/ProjectCard.astro';

interface Props {
  projects: CollectionEntry<'projects'>[];
}

const { projects } = Astro.props;
---

<section class="section" aria-labelledby="featured-projects-title">
  <div class="container">
    <div class="section-heading-row">
      <div class="section-heading">
        <p class="eyebrow">Selected projects</p>
        <h2 id="featured-projects-title">Research systems and practical software</h2>
      </div>
      <a class="text-link" href="/projects/">View all projects</a>
    </div>
    <div class="card-grid two">
      {projects.map((project) => <ProjectCard {project} />)}
    </div>
  </div>
</section>
