---
import { getCollection } from 'astro:content';
import CurrentWork from '../components/home/CurrentWork.astro';
import EditorialHero from '../components/home/EditorialHero.astro';
import ResearchList from '../components/home/ResearchList.astro';
import SelectedProjects from '../components/home/SelectedProjects.astro';
import ShortBio from '../components/home/ShortBio.astro';
import { siteDescription } from '../data/site';
import BaseLayout from '../layouts/BaseLayout.astro';

const featuredProjects = (await getCollection('projects'))
  .filter(({ data }) => data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
---

<BaseLayout description={siteDescription}>
  <EditorialHero />
  <ResearchList />
  <CurrentWork />
  <SelectedProjects projects={featuredProjects} />
  <ShortBio />
</BaseLayout>
