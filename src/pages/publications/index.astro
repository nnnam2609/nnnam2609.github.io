---
import PublicationItem from '../../components/cards/PublicationItem.astro';
import ContentLayout from '../../layouts/ContentLayout.astro';
import { getPublications } from '../../utils/collections';

const publications = (await getPublications()).sort((a, b) => b.data.year - a.data.year);
---

<ContentLayout
  title="Publications"
  description="A verified record of publications, preprints, and talks."
  eyebrow="Research record"
>
  <section class="section" aria-label="Publication list">
    <div class="container">
      {
        publications.length > 0 ? (
          publications.map((publication) => <PublicationItem {publication} />)
        ) : (
          <div class="empty-state">
            <p class="eyebrow">List in progress</p>
            <h2>The publication record is being updated.</h2>
            <p>
              Verified publication details and links will appear here as they are added. Current
              research themes are available on the research page.
            </p>
            <a class="text-link" href="/research/">
              View research themes
            </a>
          </div>
        )
      }
    </div>
  </section>
</ContentLayout>
