---
import { siteProfile } from '../../data/site';
import { cvPath } from '../../utils/cv';
import SoundToShapeVisual from './SoundToShapeVisual.astro';
---

<section class="hero">
  <div class="container hero-grid">
    <div class="hero-copy">
      <div class="researcher-id">
        <img
          class="profile-mark"
          src="/profile-nhat-nam.webp"
          alt="Portrait of Nhat-Nam Nguyen"
          width="48"
          height="48"
          decoding="async"
        />
        <div>
          <p class="name">{siteProfile.name}</p>
          <p class="location">{siteProfile.location}</p>
        </div>
      </div>
      <div class="headline-group">
        <p class="eyebrow">Sound → Representation → Articulation</p>
        <h1>From sound to shape.</h1>
        <p class="supporting-heading">{siteProfile.headline}</p>
      </div>
      <p class="lede">{siteProfile.biography[0]}</p>
      <div class="button-row">
        <a class="button" href="/research/">Explore my research</a>
        <a class="button secondary" href="/projects/">View selected projects</a>
        {
          cvPath && (
            <a class="button secondary" href={cvPath}>
              View CV
            </a>
          )
        }
      </div>
      <p class="affiliation">
        <span>{siteProfile.affiliation}</span>
        <span>{siteProfile.location}</span>
      </p>
    </div>
    <SoundToShapeVisual />
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-block: clamp(3.5rem, 7vw, 6.75rem);
    overflow: hidden;
  }

  .hero::before,
  .hero::after {
    position: absolute;
    z-index: -1;
    content: '';
    pointer-events: none;
  }

  .hero::before {
    top: -18rem;
    right: -14rem;
    width: 44rem;
    height: 44rem;
    border: 1px solid var(--line);
    border-radius: 44% 56% 56% 44%;
    opacity: 0.45;
    transform: rotate(18deg);
  }

  .hero::after {
    right: 2%;
    bottom: 8%;
    width: 32rem;
    height: 8rem;
    background: repeating-radial-gradient(
      ellipse at center,
      transparent 0 8px,
      var(--line) 9px 10px
    );
    opacity: 0.12;
  }

  .hero-grid {
    display: grid;
    gap: 3rem;
    align-items: center;
  }

  .hero-copy {
    display: grid;
    gap: 1.65rem;
  }

  .researcher-id {
    display: flex;
    gap: 0.8rem;
    align-items: center;
  }

  .profile-mark {
    width: 48px;
    height: 48px;
    border: 1px solid var(--line-strong);
    border-radius: 50%;
    background: var(--paper-raised);
    object-fit: cover;
  }

  .name {
    color: var(--ink);
    font-weight: 760;
  }

  .location {
    color: var(--ink-soft);
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }

  h1 {
    max-width: 11ch;
    font-size: clamp(3.25rem, 8vw, 6.6rem);
    letter-spacing: -0.065em;
  }

  .headline-group {
    display: grid;
    gap: 0.8rem;
  }

  .supporting-heading {
    max-width: 38rem;
    color: var(--ink-soft);
    font-size: clamp(1.05rem, 2vw, 1.3rem);
    font-weight: 650;
    line-height: 1.35;
  }

  .affiliation {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 0.8rem;
    padding-top: 1.35rem;
    border-top: 1px solid var(--line);
    color: var(--ink-soft);
    font-family: var(--font-mono);
    font-size: 0.76rem;
  }

  .affiliation span + span::before {
    margin-right: 0.8rem;
    content: '—';
  }

  @media (min-width: 62rem) {
    .hero-grid {
      grid-template-columns: minmax(0, 0.93fr) minmax(31rem, 1.07fr);
      gap: clamp(3rem, 6vw, 6rem);
    }
  }

  @media (max-width: 35rem) {
    .affiliation {
      display: grid;
    }

    .affiliation span + span::before {
      content: none;
    }
  }
</style>
