---
import { researchDirections } from '../../data/home';
---

<section class="editorial-section research-section" aria-labelledby="selected-research-title">
  <div class="container section-grid">
    <header class="section-intro">
      <p class="section-label">01 / Selected research</p>
      <h2 id="selected-research-title">Three connected research directions.</h2>
      <p>
        Speech provides the signal; imaging and geometry provide the structure needed to study how
        articulatory models generalize.
      </p>
    </header>

    <ol class="research-list" role="list">
      {
        researchDirections.map((item) => (
          <li>
            <span class="research-number" aria-hidden="true">
              {item.number}
            </span>
            <article>
              <h3>{item.title}</h3>
              <p>{item.summary}</p>
              <a href="/research/">
                Explore research <span aria-hidden="true">→</span>
              </a>
            </article>
            <p class="research-methods">
              <span>Methods</span>
              {item.methods.join(' · ')}
            </p>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .research-section {
    background: var(--color-surface);
  }

  .section-grid {
    display: grid;
    gap: 3rem;
  }

  .section-intro {
    display: grid;
    align-content: start;
    gap: 1rem;
  }

  .section-label,
  .research-number,
  .research-methods span {
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  h2 {
    max-width: 11ch;
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 5vw, 4.8rem);
    font-weight: 500;
    letter-spacing: -0.045em;
    line-height: 0.98;
  }

  .section-intro > p:last-child {
    max-width: 32rem;
    color: var(--color-muted);
  }

  .research-list,
  .research-list li {
    display: grid;
  }

  .research-list {
    border-top: 1px solid var(--color-line-strong);
  }

  .research-list li {
    padding-block: clamp(1.8rem, 4vw, 3.2rem);
    gap: 1rem;
    border-bottom: 1px solid var(--color-line);
  }

  .research-list article {
    display: grid;
    gap: 0.8rem;
  }

  h3 {
    max-width: 22ch;
    font-family: var(--font-display);
    font-size: clamp(1.65rem, 3vw, 2.65rem);
    font-weight: 500;
    letter-spacing: -0.025em;
    line-height: 1.08;
  }

  article p {
    max-width: 38rem;
    color: var(--color-muted);
  }

  article a {
    display: inline-flex;
    width: max-content;
    min-height: 44px;
    gap: 0.45rem;
    align-items: center;
    color: var(--color-text);
    font-size: 0.83rem;
    font-weight: 700;
    text-decoration: none;
  }

  article a span {
    color: var(--color-accent);
  }

  .research-methods {
    display: grid;
    align-content: start;
    gap: 0.4rem;
    color: var(--color-muted);
    font-size: 0.76rem;
    line-height: 1.5;
  }

  @media (min-width: 56rem) {
    .section-grid {
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: clamp(2rem, 4vw, 4rem) clamp(1rem, 1.8vw, 2rem);
    }

    .section-intro {
      position: sticky;
      top: 8rem;
      grid-column: 1 / 5;
      align-self: start;
    }

    .research-list {
      grid-column: 5 / 13;
    }

    .research-list li {
      grid-template-columns: minmax(2rem, 0.45fr) minmax(0, 4fr) minmax(9rem, 1.35fr);
      gap: clamp(1rem, 2.5vw, 2.5rem);
    }
  }
</style>
