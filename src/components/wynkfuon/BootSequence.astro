<section
  class="system-screen boot-screen"
  id="boot-screen"
  data-screen="boot"
  aria-live="polite"
  hidden
>
  <div class="boot-terminal">
    <div class="boot-mark" aria-hidden="true">W<span>♥</span></div>
    <p class="system-kicker">Wynkfuon.exe bootloader</p>
    <ol class="boot-log" aria-label="System boot progress">
      <li data-boot-line>Mounting shared memories...</li>
      <li data-boot-line>Loading chaotic video codecs...</li>
      <li data-boot-line>Checking heart compatibility... 100%</li>
      <li data-boot-line>Opening our little world...</li>
    </ol>
    <div class="boot-progress" aria-hidden="true"><span></span></div>
    <button class="text-button" id="skip-boot" type="button">Skip boot [Enter]</button>
  </div>
</section>
