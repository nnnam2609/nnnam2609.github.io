---
import { navigation, siteProfile } from '../../data/site';

const socialLinks = [
  siteProfile.github && { href: siteProfile.github, label: 'GitHub' },
  siteProfile.linkedin && { href: siteProfile.linkedin, label: 'LinkedIn' },
  siteProfile.scholar && { href: siteProfile.scholar, label: 'Google Scholar' },
  siteProfile.orcid && { href: siteProfile.orcid, label: 'ORCID' },
].filter(Boolean) as { href: string; label: string }[];
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <p class="footer-name">{siteProfile.name}</p>
      <p>{siteProfile.position} · {siteProfile.location}</p>
    </div>
    <nav aria-label="Footer navigation">
      <ul role="list">
        {
          navigation.slice(1).map(({ href, label }) => (
            <li>
              <a href={href}>{label}</a>
            </li>
          ))
        }
      </ul>
    </nav>
    {
      socialLinks.length > 0 && (
        <nav aria-label="Social links">
          <ul role="list">
            {socialLinks.map(({ href, label }) => (
              <li>
                <a href={href} rel="me">
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      )
    }
  </div>
  <div class="container footer-bottom">
    <span>© {new Date().getFullYear()} {siteProfile.name}</span>
    <span>Built with Astro. No tracking.</span>
  </div>
</footer>

<style>
  .site-footer {
    padding-block: 3rem 1.5rem;
    border-top: 1px solid var(--line);
    color: var(--ink-soft);
    font-size: 0.86rem;
  }

  .footer-grid {
    display: grid;
    gap: 2rem;
  }

  .footer-name {
    margin-bottom: 0.35rem;
    color: var(--ink);
    font-weight: 750;
  }

  ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 1rem;
  }

  a {
    display: inline-flex;
    min-height: 36px;
    align-items: center;
  }

  .footer-bottom {
    display: flex;
    padding-top: 2rem;
    gap: 0.75rem 2rem;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid var(--line);
    margin-top: 2rem;
  }

  @media (min-width: 48rem) {
    .footer-grid {
      grid-template-columns: minmax(16rem, 1fr) auto auto;
    }
  }

  @media (max-width: 36rem) {
    .footer-bottom {
      align-items: start;
      flex-direction: column;
    }
  }
</style>
