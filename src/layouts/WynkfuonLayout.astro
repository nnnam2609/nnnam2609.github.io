---
import { assetPath } from '../utils/assetPath';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Wynkfuon.exe', description = 'A private little archive of memories.' } =
  Astro.props;
const canonical = new URL('/wynkfuon/', Astro.site);
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#15132c" />
    <link rel="icon" type="image/svg+xml" href={assetPath('favicon.svg')} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
