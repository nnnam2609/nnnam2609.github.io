---
import { navigation } from '../../data/site';

interface Props {
  pathname: string;
}

const { pathname } = Astro.props;
const isActive = (href: string) => (href === '/' ? pathname === '/' : pathname.startsWith(href));
const primaryNavigation = navigation.slice(1);
---

<nav class="desktop-nav" aria-label="Primary navigation">
  <ul class="desktop-list" role="list">
    {
      primaryNavigation.map(({ href, label }) => (
        <li>
          <a href={href} aria-current={isActive(href) ? 'page' : undefined}>
            {label}
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<nav class="mobile-nav" aria-label="Mobile navigation">
  <details>
    <summary aria-expanded="false" data-mobile-summary>
      <span>Menu</span>
      <svg aria-hidden="true" viewBox="0 0 16 16" width="16" height="16">
        <path d="m3 6 5 5 5-5"></path>
      </svg>
    </summary>
    <ul class="nav-list" role="list">
      {
        primaryNavigation.map(({ href, label }) => (
          <li>
            <a href={href} aria-current={isActive(href) ? 'page' : undefined}>
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </details>
</nav>

<script>
  document.querySelectorAll<HTMLDetailsElement>('.mobile-nav details').forEach((details) => {
    const summary = details.querySelector<HTMLElement>('[data-mobile-summary]');
    const updateState = () => summary?.setAttribute('aria-expanded', String(details.open));

    details.addEventListener('toggle', updateState);
    details
      .querySelectorAll('a')
      .forEach((link) => link.addEventListener('click', () => details.removeAttribute('open')));
    updateState();
  });
</script>

<style>
  details {
    position: relative;
  }

  .desktop-nav {
    display: none;
  }

  summary {
    display: inline-flex;
    min-height: 44px;
    padding: 0.5rem 0;
    gap: 0.45rem;
    align-items: center;
    border: 0;
    background: transparent;
    color: var(--color-text);
    cursor: pointer;
    font-size: 0.85rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    list-style: none;
    text-transform: uppercase;
  }

  summary::-webkit-details-marker {
    display: none;
  }

  summary svg {
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.6;
    transition: transform 160ms ease;
  }

  details[open] summary svg {
    transform: rotate(180deg);
  }

  .nav-list {
    position: absolute;
    z-index: 20;
    top: calc(100% + 0.55rem);
    right: 0;
    width: min(17rem, calc(100vw - 2rem));
    padding: 0.5rem;
    border: 1px solid var(--color-line-strong);
    background: var(--color-surface);
    box-shadow: 0 12px 32px rgb(20 29 26 / 12%);
  }

  a {
    display: flex;
    min-height: 44px;
    padding: 0.5rem 0.7rem;
    align-items: center;
    color: var(--color-muted);
    font-size: 0.86rem;
    font-weight: 650;
    text-decoration: none;
  }

  a:hover,
  a[aria-current='page'] {
    color: var(--color-accent);
  }

  @media (min-width: 52rem) {
    .mobile-nav {
      display: none;
    }

    .desktop-nav {
      display: block;
    }

    .desktop-list {
      display: flex;
      gap: clamp(0.25rem, 1vw, 1rem);
    }

    a {
      min-height: 40px;
      padding-inline: 0.2rem;
      border-bottom: 1px solid transparent;
      font-size: 0.78rem;
      font-weight: 650;
    }

    a[aria-current='page'] {
      border-bottom-color: var(--color-accent);
    }
  }
</style>
