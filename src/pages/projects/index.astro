---
import { getCollection } from 'astro:content';
import ProjectCard from '../../components/cards/ProjectCard.astro';
import ContentLayout from '../../layouts/ContentLayout.astro';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const researchProjects = projects.filter(({ data }) => data.type === 'research');
const softwareProjects = projects.filter(({ data }) => data.type === 'software');
---

<ContentLayout
  title="Projects"
  description="Research projects and practical software explorations, presented without unverified claims or placeholder links."
  eyebrow="Research systems · useful tools"
>
  {
    researchProjects.length > 0 && (
      <section class="section" aria-labelledby="research-projects-title">
        <div class="container">
          <div class="section-heading">
            <p class="eyebrow">Research</p>
            <h2 id="research-projects-title">Articulatory modelling and representation learning</h2>
          </div>
          <div class="card-grid three">
            {researchProjects.map((project) => (
              <ProjectCard {project} />
            ))}
          </div>
        </div>
      </section>
    )
  }
  {
    softwareProjects.length > 0 && (
      <section class="section" aria-labelledby="software-projects-title">
        <div class="container">
          <div class="section-heading">
            <p class="eyebrow">Software</p>
            <h2 id="software-projects-title">Focused systems for real work</h2>
          </div>
          <div class="card-grid two">
            {softwareProjects.map((project) => (
              <ProjectCard {project} />
            ))}
          </div>
        </div>
      </section>
    )
  }
</ContentLayout>
