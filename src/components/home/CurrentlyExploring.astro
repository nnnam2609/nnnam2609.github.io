---
import { explorationItems } from '../../data/home';
---

<aside class="exploring" aria-labelledby="exploring-title">
  <div class="container exploring-inner">
    <p class="label" id="exploring-title">Currently exploring</p>
    <ul role="list">
      {
        explorationItems.map(({ topic, status }) => (
          <li>
            <span class="status-dot" aria-hidden="true" />
            <span>{topic}</span>
            <small>{status}</small>
          </li>
        ))
      }
    </ul>
  </div>
</aside>

<style>
  .exploring {
    border-block: 1px solid var(--line);
    background: color-mix(in srgb, var(--paper-raised) 76%, transparent);
  }

  .exploring-inner {
    display: grid;
    padding-block: 1.2rem;
    gap: 1rem;
  }

  .label {
    color: var(--accent-strong);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  ul {
    display: flex;
    gap: 0.7rem;
    overflow-x: auto;
    padding: 0 0 0.2rem;
    scrollbar-width: thin;
  }

  li {
    display: inline-flex;
    flex: 0 0 auto;
    min-height: 38px;
    padding: 0.45rem 0.7rem;
    gap: 0.48rem;
    align-items: center;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--paper);
    color: var(--ink);
    font-size: 0.78rem;
  }

  small {
    color: var(--ink-soft);
    font-family: var(--font-mono);
    font-size: 0.62rem;
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-soft);
  }

  @media (min-width: 65rem) {
    .exploring-inner {
      grid-template-columns: auto minmax(0, 1fr);
      align-items: center;
    }
  }
</style>
